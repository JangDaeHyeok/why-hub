# 환경변수 템플릿. 이 파일을 복사해 `.env` 로 만들고 실제 값을 채운다.
#   cp .env.example .env
# `.env` 는 .gitignore 로 무시되며, `docker compose` 는 이 파일을 자동 로드한다.
# 로컬(비도커) 실행 시엔 아래 값들을 셸에서 export 하면 된다.

# ── LLM 엔드포인트 (Anthropic 스타일 · 스트리밍/논스트리밍) ────────────────
# 인증 없는 공개 URL(=시크릿성)이라 git 에 커밋하지 않는다. 미설정 시 AI 기능만 graceful skip.
KNOWLEDGE_HUB_LLM_COMPLETE_URL=   # 논스트리밍 엔드포인트 URL
KNOWLEDGE_HUB_LLM_STREAM_URL=     # 스트리밍 엔드포인트 URL

# ── 배포(docker-compose) 전용 ──────────────────────────────────────────────
# PostgreSQL 비밀번호 (미설정 시 compose 기본값 hubpw).
PGPASSWORD=hubpw
