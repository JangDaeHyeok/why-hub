# 환경변수 템플릿. 이 파일을 복사해 `.env` 로 만들고 실제 값을 채운다.
#   cp .env.example .env
# `.env` 는 .gitignore 로 무시되며, `docker compose` 는 이 파일을 자동 로드한다.
# 로컬(비도커) 실행 시엔 아래 값들을 셸에서 export 하면 된다.

# ── LLM 엔드포인트 (Anthropic 스타일 · 스트리밍/논스트리밍) ────────────────
# 인증 없는 공개 URL(=시크릿성)이라 git 에 커밋하지 않는다. 미설정 시 AI 기능만 graceful skip.
KNOWLEDGE_HUB_LLM_COMPLETE_URL=   # 논스트리밍 엔드포인트 URL
KNOWLEDGE_HUB_LLM_STREAM_URL=     # 스트리밍 엔드포인트 URL

# ── 배포(docker-compose) 전용 ──────────────────────────────────────────────
# PostgreSQL 비밀번호. hub=슈퍼유저(초기화), hub_admin/hub_mcp=앱 롤(롤 분리).
PGPASSWORD=hubpw
HUB_ADMIN_PASSWORD=change-me-admin      # admin 컨테이너 DB 롤(auth+knowledge)
HUB_MCP_PASSWORD=change-me-mcp          # mcp 컨테이너 DB 롤(knowledge only)

# ── 인증 시크릿 (구현스펙-인증인가-RBAC.md §8) — 절대 커밋 금지 ─────────────
# PAT 해시용 pepper, 세션 토큰 HMAC secret. 길고 무작위인 값으로 생성:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_PAT_PEPPER=change-me-pepper
AUTH_SESSION_SECRET=change-me-session-secret
# JWT issuer/audience (기본값이 있으므로 선택).
AUTH_ISSUER=why-hub
AUTH_MCP_AUDIENCE=why-hub-mcp
# RSA 키는 파일로 주입한다(compose 가 ./secrets/*.pem 을 마운트). 커밋 금지:
#   mkdir -p secrets
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out secrets/jwt_private.pem
#   openssl rsa -pubout -in secrets/jwt_private.pem -out secrets/jwt_public.pem
